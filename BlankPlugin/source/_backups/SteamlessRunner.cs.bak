using Playnite.SDK;
using System;
using System.Collections.Generic;
using System.Diagnostics;
using System.IO;
using System.Reflection;

namespace BlankPlugin
{
    /// <summary>
    /// Strips Steam DRM from .exe files using Steamless.CLI.dll.
    /// Mirrors ACCELA's SteamlessIntegration logic.
    /// </summary>
    public class SteamlessRunner
    {
        private static readonly ILogger logger = LogManager.GetLogger();

        private readonly string _dotnetPath;
        private readonly string _steamlessDll;

        public SteamlessRunner(string dotnetPath)
        {
            _dotnetPath = dotnetPath;
            _steamlessDll = Path.Combine(GetPluginDir(), "deps", "Steamless", "Steamless.CLI.dll");
        }

        public bool IsReady => !string.IsNullOrEmpty(_dotnetPath) && File.Exists(_steamlessDll);

        public void Run(string gameDirectory, Action<string> onLog)
        {
            if (!IsReady)
            {
                onLog("ERROR: Steamless not available.");
                return;
            }

            var exeFiles = FindExecutables(gameDirectory);
            if (exeFiles.Count == 0)
            {
                onLog("No .exe files found in " + gameDirectory);
                return;
            }

            foreach (var exe in exeFiles)
            {
                onLog("Running Steamless on: " + exe);
                RunSteamless(exe, onLog);
            }
        }

        private void RunSteamless(string exePath, Action<string> onLog)
        {
            var args = string.Format("\"{0}\" --quiet \"{1}\"", _steamlessDll, exePath);
            var psi = new ProcessStartInfo(_dotnetPath, args)
            {
                UseShellExecute = false,
                RedirectStandardOutput = true,
                RedirectStandardError = true,
                CreateNoWindow = true
            };

            using (var proc = new Process { StartInfo = psi })
            {
                proc.Start();
                string line;
                while ((line = proc.StandardOutput.ReadLine()) != null)
                    onLog(line);
                proc.WaitForExit();

                if (proc.ExitCode != 0)
                    onLog("WARNING: Steamless exited with code " + proc.ExitCode + " for " + exePath);
                else
                    onLog("Steamless OK: " + Path.GetFileName(exePath));
            }
        }

        private static List<string> FindExecutables(string dir)
        {
            var result = new List<string>();
            if (!Directory.Exists(dir)) return result;

            foreach (var exe in Directory.GetFiles(dir, "*.exe", SearchOption.AllDirectories))
            {
                var name = Path.GetFileNameWithoutExtension(exe).ToLowerInvariant();
                // Skip obvious non-game executables
                if (name.Contains("unins") || name.Contains("setup") ||
                    name.Contains("redist") || name.Contains("vc_") ||
                    name.Contains("directx") || name.Contains("dxsetup"))
                    continue;

                result.Add(exe);
            }

            return result;
        }

        private static string GetPluginDir()
            => Path.GetDirectoryName(Assembly.GetExecutingAssembly().Location);
    }
}
